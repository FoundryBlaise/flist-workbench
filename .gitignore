node_modules/
out/
dist/
.vite/
*.log
.DS_Store

# Python
__pycache__/
*.py[cod]
.venv/
.uv-cache/

# TypeScript composite build artifacts
*.tsbuildinfo

# Test artifacts
playwright-report/
test-results/
tests/screenshots/*.png

# Electron-builder output (Phase 6 Windows packaging — see docs/PACKAGING_WINDOWS.md)
release/
dist-electron/
# Bundled sidecar binary produced by `npm run pack:sidecar`. ~30 MB,
# regenerated from source on every pack — never check it in.
resources/sidecar.exe
resources/sidecar
# PyInstaller intermediate output (the dist/ entry above also covers
# sidecar/dist/ from running PyInstaller directly).
sidecar/build/
sidecar/dist/
# Auto-generated spec file from `npm run pack:sidecar`. Has absolute
# paths baked in, so it's per-machine — the npm script regenerates it
# from CLI args on every build.
sidecar/sidecar.spec

# OS / editor cruft
Thumbs.db
ehthumbs.db
desktop.ini
.idea/
.vscode/

# Lockfiles — package-lock.json IS tracked (npm convention). uv.lock
# for the sidecar IS tracked. Anything pip generates ad-hoc isn't.
pip-wheel-metadata/
